[info] >  \[ 54 \leq 2(17) + H \leq 70 \] {"user":"\\[ 54 \\leq 2(17) + H \\leq 70 \\]","metadata":{"emulator":{"name":"functions"},"function":{"name":"us-central1-handleUserQuery"},"extension":{},"message":"\u001b[90m> \u001b[39m \\[ 54 \\leq 2(17) + H \\leq 70 \\]"}}
